{
  "name": "vault-agent",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "packages/core",
    "packages/server",
    "packages/cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs'); for (const dir of ['packages/core/dist','packages/server/dist','packages/cli/dist']) fs.rmSync(dir, { recursive: true, force: true });\"",
    "build": "npm run build --workspaces",
    "typecheck": "npm run build --workspace @vault-agent/core && npm run build --workspace @vault-agent/server && npm run typecheck --workspaces",
    "lint": "eslint packages/*/src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --exclude packages/cli/test/mcp-stdio.test.ts --exclude packages/cli/test/serve-mcp-flags.test.ts",
    "test:dist": "vitest run packages/cli/test/mcp-stdio.test.ts packages/cli/test/serve-mcp-flags.test.ts",
    "test:watch": "vitest --exclude packages/cli/test/mcp-stdio.test.ts --exclude packages/cli/test/serve-mcp-flags.test.ts",
    "dev:server": "tsx packages/server/src/main.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.26.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
