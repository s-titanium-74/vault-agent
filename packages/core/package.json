{
  "name": "@vault-agent/core",
  "version": "0.1.0",
  "description": "Core Markdown vault indexing, retrieval, and search logic for vault-agent.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s-titanium-74/vault-agent.git",
    "directory": "packages/core"
  },
  "keywords": [
    "markdown",
    "vault",
    "search",
    "retrieval"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.0",
    "env-paths": "^4.0.0",
    "ignore": "^7.0.0",
    "mime-types": "^3.0.1",
    "smol-toml": "^1.3.1",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mime-types": "^3.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
