  },
  "scripts": {
    "build": "tsup",
    "postbuild": "chmod +x dist/main.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vault-agent/core": "0.1.1",
    "@vault-agent/server": "0.1.1",
    "commander": "^13.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
