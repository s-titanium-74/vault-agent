{
  "name": "@vault-agent/cli",
  "version": "0.1.1",
  "description": "Command line interface for vault-agent.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "vault-agent": "dist/main.js"
  },
  "files": [
    "dist",
    "src",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s-titanium-74/vault-agent.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "markdown",
    "vault",
    "search",
    "retrieval",
    "mcp",
    "cli"
  ],
  "publishConfig": {
